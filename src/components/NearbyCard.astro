---
interface Props {
  name: string;
  distance: string;
  description: string;
  href?: string;
  target?: string;
  imgSrc?: string;
  imgAlt?: string;
}
const { name, distance, description, href = '#', target, imgSrc = '', imgAlt = '' } = Astro.props;
---
<a class="near" href={href} target={target} rel={target === '_blank' ? 'noopener noreferrer' : undefined}>
  <div class:list={['near-bg', ...(!imgSrc ? ['ph', 'ph--navy'] : [])]}>
    {imgSrc && <img src={imgSrc} alt={imgAlt} width="480" height="600" />}
  </div>
  <div class="cap">
    <div class="dist">{distance}</div>
    <h3>{name}</h3>
    <p>{description}</p>
  </div>
</a>

<style>
.near {
  position: relative; border-radius: var(--radius-lg); overflow: hidden;
  aspect-ratio: 4/5; display: flex; align-items: flex-end; color: #fff;
  isolation: isolate; transition: transform .22s;
}
.near:hover { transform: translateY(-4px); }
.near-bg { position: absolute; inset: 0; z-index: -2; }
.near-bg img { width: 100%; height: 100%; object-fit: cover; display: block; }
.near::after {
  content: ""; position: absolute; inset: 0; z-index: -1;
  background: linear-gradient(180deg, transparent 30%, rgba(13,32,50,.88));
}
.cap { padding: 24px; }
.dist { font-family: var(--font-mono); font-size: 12px; color: var(--orange-bright); letter-spacing: .06em; }
h3 { font-size: 24px; text-transform: uppercase; margin-top: 6px; }
p { font-size: 14px; color: #dbe2e9; margin: 6px 0 0; }
</style>
