---
interface Props {
  label?: string;
  variant?: 'primary' | 'navy' | 'ghost' | 'ghost-light';
  scheduleUuid?: string;
}
const {
  label = 'Book a Tour',
  variant = 'primary',
  scheduleUuid = '12a444fc-2b10-434a-96ac-cec5050ac680',
} = Astro.props;

const href = `https://fareharbor.com/embeds/book/antelopecanyonaz/?ref=valerie&schedule-uuid=${scheduleUuid}&full-items=yes&flow=1234128`;
---
<a
  class={`btn btn--${variant} fh-booking`}
  href={href}
>
  {label}
</a>

<!--
  No FareHarbor third-party script: the click is handled by the shared
  in-page booking modal in Base.astro (it loads the booking URL in an
  iframe), the same path every other booking link uses. If JS is
  unavailable, the link still navigates to the FareHarbor booking page.
-->

