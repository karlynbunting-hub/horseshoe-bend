---
import '../styles/brand.css';
import { webPage } from '../data/entities';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  /** ISO date (YYYY-MM-DD); when set, emits WebPage freshness schema */
  updated?: string;
  /** ISO date (YYYY-MM-DD) the page was first published */
  published?: string;
}

const {
  title,
  description = 'Horseshoe Bend — Plan your visit to Page, Arizona. Entrance fees, parking, guided tours, Antelope Canyon combos, and river adventures.',
  canonical,
  ogImage = '/images/og-default.webp',
  updated,
  published,
} = Astro.props;

const gaId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID;
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, 'https://horseshoebend.com').href;
// OG/Twitter scrapers require an absolute image URL
const ogImageUrl = new URL(ogImage, 'https://horseshoebend.com').href;

// Freshness: a self-contained WebPage node with datePublished/dateModified
const freshnessSchema = updated
  ? {
      '@context': 'https://schema.org',
      ...webPage({ url: canonicalUrl, name: title, description, datePublished: published, dateModified: updated }),
    }
  : null;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />

  <!-- Favicons -->
  <link rel="icon" href="/favicon.ico" sizes="any" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />

  <!-- Open Graph -->
  <meta property="og:site_name" content="HorseshoeBend.com" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImageUrl} />
  <meta property="og:image:type" content="image/webp" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt" content="Horseshoe Bend overlook near Page, Arizona" />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalUrl} />

  <!-- Twitter / X Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageUrl} />

  <!-- Font preconnect -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

  <!-- GA4 — loads on every page; straight install (US-dominant audience, no consent banner) -->
  {gaId && (
    <>
      <script async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script>
      <script is:inline define:vars={{ gaId }}>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', gaId);
      </script>
    </>
  )}

  {freshnessSchema && (
    <script type="application/ld+json" set:html={JSON.stringify(freshnessSchema)} />
  )}

  <slot name="head" />
</head>
<body>
  <slot />

  <!-- FareHarbor booking modal -->
  <div id="fh-overlay" role="dialog" aria-modal="true" aria-label="Book a tour">
    <div class="fh-sheet">
      <button id="fh-close" aria-label="Close booking">&times;</button>
      <iframe id="fh-iframe" src="" title="Book a tour" allowpaymentrequest></iframe>
    </div>
  </div>
</body>
</html>

<style is:global>
#fh-overlay {
  display: none;
  position: fixed;
  inset: 0;
  z-index: 500;
  background: rgba(13, 32, 50, 0.78);
  backdrop-filter: blur(4px);
  -webkit-backdrop-filter: blur(4px);
  padding: 24px 16px;
  box-sizing: border-box;
  overflow-y: auto;
}
#fh-overlay.open { display: flex; align-items: flex-start; justify-content: center; }
.fh-sheet {
  position: relative;
  width: min(820px, 100%);
  margin: auto;
  border-radius: 12px;
  overflow: hidden;
  background: #fff;
  box-shadow: 0 24px 80px rgba(0,0,0,.4);
}
#fh-close {
  position: absolute;
  top: 10px;
  right: 10px;
  z-index: 10;
  width: 34px;
  height: 34px;
  border-radius: 50%;
  border: none;
  background: rgba(0,0,0,.55);
  color: #fff;
  font-size: 20px;
  line-height: 1;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
}
#fh-close:hover { background: rgba(0,0,0,.8); }
#fh-iframe {
  display: block;
  width: 100%;
  height: 82vh;
  border: none;
}
</style>

<script>
  const overlay = document.getElementById('fh-overlay');
  const iframe  = document.getElementById('fh-iframe') as HTMLIFrameElement | null;
  const closeBtn = document.getElementById('fh-close');

  function openModal(url: string) {
    if (!overlay || !iframe) return;
    iframe.src = url;
    overlay.classList.add('open');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    if (!overlay || !iframe) return;
    overlay.classList.remove('open');
    iframe.src = '';
    document.body.style.overflow = '';
  }

  document.addEventListener('click', (e) => {
    const link = (e.target as Element).closest('a[href*="fareharbor.com/embeds/book"]') as HTMLAnchorElement | null;
    if (!link) return;
    if (link.target === '_blank') return; // let browser open in new tab
    e.preventDefault();
    openModal(link.href);
  });

  closeBtn?.addEventListener('click', closeModal);
  overlay?.addEventListener('click', (e) => { if (e.target === overlay) closeModal(); });
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });
</script>
