---
import Base from './Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
}
const props = Astro.props;
---
<Base {...props}>
  <slot name="head" slot="head" />
  <Nav />
  <main id="content">
    <slot />
  </main>
  <Footer />
</Base>
